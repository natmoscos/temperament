# Google AdSense 퍼블리셔 ID
# AdSense 승인 후 ca-pub-XXXXXXXXXXXXXXXX 형태로 입력
NEXT_PUBLIC_ADSENSE_ID=

# Google Analytics 4 측정 ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# 사이트 URL (Vercel 배포 후 설정)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 카카오 JavaScript SDK (카카오톡 공유)
# https://developers.kakao.com 에서 앱 생성 후 JavaScript 키 입력
NEXT_PUBLIC_KAKAO_JS_KEY=

# 토스페이먼츠 (결제 연동)
# 설정하지 않으면 PDF 무료 다운로드로 동작
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_XXXXXXXX
TOSS_SECRET_KEY=test_sk_XXXXXXXX
